{
  "name": "taskflow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b && tsc --noEmit -p backend/tsconfig.json",
    "build": "npm run typecheck && vite build && tsc -p backend/tsconfig.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "backend:dev": "tsx backend/src/server.ts",
    "backend:typecheck": "tsc --noEmit -p backend/tsconfig.json",
    "backend:build": "tsc -p backend/tsconfig.json"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "tsx": "^4.21.0"
  }
}
